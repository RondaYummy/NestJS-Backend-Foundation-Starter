NODE_ENV=development
APP_PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis startup policy for Worker
REDIS_STARTUP_MAX_ATTEMPTS=5
REDIS_STARTUP_RETRY_DELAY_MS=1000
REDIS_CONNECT_TIMEOUT_MS=3000

# BullMQ
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY=5000

# Mail
MAIL_DRIVER=null
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Rate Limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
# Login / register (per IP)
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX=5
LOGGER_LEVEL=debug

# Auth
# jwt, session
AUTH_DRIVER=jwt
AUTH_SESSION_TTL_SECONDS=604800

AUTH_SESSION_COOKIE_NAME=sid
AUTH_SESSION_COOKIE_PATH=/
AUTH_SESSION_COOKIE_DOMAIN=
AUTH_SESSION_COOKIE_SAME_SITE=lax

JWT_SECRET=dev-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

PASSWORD_SALT_ROUNDS=10

CORS_ORIGINS=http://localhost:3000,https://example.com