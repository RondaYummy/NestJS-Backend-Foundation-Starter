NODE_ENV=development
# Logging format: NODE_ENV=development enables human-readable pino-pretty via AppLogger;
# NODE_ENV=test or production keeps structured JSON on stdout (no pretty transport).
APP_PORT=3000
# Swagger UI (/docs) and OpenAPI JSON (/docs-json). Defaults on outside production and off in production.
API_DOCS_ENABLED=true

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis startup policy (API, Worker, Cron)
REDIS_STARTUP_MAX_ATTEMPTS=5
REDIS_STARTUP_RETRY_DELAY_MS=1000
REDIS_CONNECT_TIMEOUT_MS=3000
# Logical Redis namespace applied by RedisService (default: app). Change per project/env when sharing one Redis DB.
REDIS_KEY_PREFIX=app

# Health checks — per-dependency probe deadline; align with orchestrator probe timeout
HEALTH_CHECK_TIMEOUT_MS=3000

# BullMQ
BULLMQ_DEFAULT_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY=5000

# Outbox processor
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_LOCK_TTL_MS=300000
OUTBOX_HEARTBEAT_INTERVAL_MS=100000
# 0 = disabled; when > 0, failure is recorded after handler settlement (no concurrent reclaim)
OUTBOX_HANDLER_TIMEOUT_MS=0
OUTBOX_POLL_INTERVAL_MS=60000
OUTBOX_CRON_LOCK_TTL_MS=55000
OUTBOX_CONCURRENCY=1
OUTBOX_RETRY_BASE_DELAY_SECONDS=30
OUTBOX_RETRY_MAX_DELAY_SECONDS=3600

# Job execution lease (worker idempotency)
JOB_EXECUTION_LEASE_TTL_SECONDS=300
JOB_EXECUTION_HEARTBEAT_INTERVAL_SECONDS=100
JOB_EXECUTION_COMPLETED_RETENTION_TTL_SECONDS=2592000

# Mail
MAIL_DRIVER=null
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Rate Limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
# Login / register (per IP)
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX=5
# Log level for AppLogger / pino (applies in both pretty and JSON modes).
LOGGER_LEVEL=debug

# Auth
# jwt, session
AUTH_DRIVER=jwt
AUTH_SESSION_TTL_SECONDS=604800

AUTH_SESSION_COOKIE_NAME=sid
AUTH_SESSION_COOKIE_PATH=/
AUTH_SESSION_COOKIE_DOMAIN=
AUTH_SESSION_COOKIE_SAME_SITE=lax

# Dev/test placeholders only. Production requires independently generated secrets (see README §21).
JWT_SECRET=dev-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

PASSWORD_SALT_ROUNDS=10

# Password reset (forgot-password flow)
# One-time reset token lifetime in seconds (default 30 minutes).
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
# Optional frontend URL for reset emails; when set, the email links to
# ${PASSWORD_RESET_URL_BASE}?token=<raw-token>. Leave empty to send the raw token only.
# Reset emails are delivered via the Worker email queue and require MAIL_DRIVER=smtp (+ SMTP_*) for real delivery.
PASSWORD_RESET_URL_BASE=

# Google SSO (optional module, disabled by default)
# When enabled, GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / GOOGLE_REDIRECT_URI are required (fail-fast validation).
# Routes GET /v1/auth/google and GET /v1/auth/google/callback return 503 GOOGLE_SSO_DISABLED while disabled.
GOOGLE_SSO_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the redirect URI registered in the Google Cloud console, e.g.
# http://localhost:3000/v1/auth/google/callback (HTTPS required outside local development).
GOOGLE_REDIRECT_URI=
# Optional Google Workspace hosted-domain restriction (hd); empty = any Google account.
GOOGLE_SSO_HOSTED_DOMAIN=
# Optional default returnUrl for the browser redirect flow; its origin must be listed in CORS_ORIGINS.
# Only used with AUTH_DRIVER=session (JWT artifacts are never delivered via redirects).
GOOGLE_SSO_DEFAULT_RETURN_URL=
# One-time OAuth state TTL in seconds (CSRF protection).
GOOGLE_SSO_STATE_TTL_SECONDS=600

CORS_ORIGINS=http://localhost:3000,https://example.com