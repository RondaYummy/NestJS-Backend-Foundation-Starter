{
  "name": "nestjs-backend-foundation-starter",
  "author": "RondoYummy <halevych.dev@gmail.com>",
  "version": "1.0.0",
  "private": true,
  "license": "ISC",
  "description": "NestJS starter-kit with Onion Architecture and multi-entrypoint API/Worker/Cron.",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "scripts": {
    "start:api": "nest start api",
    "start:worker": "nest start worker",
    "start:cron": "nest start cron",
    "start:dev:api": "nest start api --watch",
    "start:dev:worker": "nest start worker --watch",
    "start:dev:cron": "nest start cron --watch",
    "build": "nest build api && nest build worker && nest build cron && nest build migrations",
    "build:api": "nest build api",
    "build:worker": "nest build worker",
    "build:cron": "nest build cron",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && echo \"✅ Database migrations applied successfully\"",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.ts",
    "test:int": "jest --config jest.integration.config.ts",
    "start:prod:api": "node dist/apps/api/apps/api/src/main.js",
    "start:prod:worker": "node dist/apps/worker/apps/worker/src/main.js",
    "start:prod:cron": "node dist/apps/cron/apps/cron/src/main.js",
    "start:prod:migrations": "node dist/apps/migrations/main.js",
    "build:migrations": "nest build migrations",
    "db:migrate:prod": "npm run start:prod:migrations"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/terminus": "^11.1.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "ms": "^2.1.3",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
