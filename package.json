{
  "name": "nestjs-backend-foundation-starter",
  "author": "RondoYummy <halevych.dev@gmail.com>",
  "version": "1.0.0",
  "private": true,
  "license": "ISC",
  "description": "NestJS starter-kit with Onion Architecture and multi-entrypoint API/Worker/Cron.",
  "engines": {
    "node": "^24",
    "npm": ">= 11.7.0"
  },
  "scripts": {
    "start:api": "nest start api",
    "start:worker": "nest start worker",
    "start:cron": "nest start cron",
    "start:dev:api": "nest start api --watch",
    "start:dev:worker": "nest start worker --watch",
    "start:dev:cron": "nest start cron --watch",
    "build": "nest build api && nest build worker && nest build cron",
    "build:api": "nest build api",
    "build:worker": "nest build worker",
    "build:cron": "nest build cron",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && echo \"✅ Database migrations applied successfully\"",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.ts",
    "test:int": "jest --config jest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.632.0",
    "@aws-sdk/s3-request-presigner": "^3.632.0",
    "@nestjs/bullmq": "^10.2.2",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/terminus": "^10.2.3",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.12.7",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.33.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.1",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.6",
    "@types/react": "^19.2.16",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.29.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
